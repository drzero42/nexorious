# Go binaries
/nexorious
/nexctl

# Frontend build output (populated by make frontend)
ui/frontend/dist/*
!ui/frontend/dist/.gitkeep
ui/frontend/node_modules/

# Changelog embed data (populated by build steps)
internal/changelog/data/*
!internal/changelog/data/.gitkeep

# devenv
.devenv/
.devenv.flake.nix
# Generated from devenv.nix git-hooks on shell entry; do not commit.
.pre-commit-config.yaml

.env

# Worktrees
.worktrees/

storage

# Test coverage files
coverage.out
coverage.html

# Log files
*.log

# Legendary per-user working directories
.legendary-work/

# Superpowers brainstorm artifacts
.superpowers/

# Test deployment values for helm chart
deploy/nexorious-values.yaml

# Nix build artifacts (`result`, plus `result-1`, `result-2`, … when building
# multiple installables in one `nix build`)
result
result-*