# Nexorious environment variables
# Copy this file to .env and fill in the values.
# The .env file is gitignored and never committed.

# Database connection
DATABASE_URL=postgres://nexorious:yourpassword@localhost:5432/nexorious?sslmode=disable

# DB encryption key for at-rest credential encryption — generate: openssl rand -base64 32
DB_ENCRYPTION_KEY=your-db-encryption-key-here

# IGDB API credentials — required for game search and metadata
# Setup guide: docs/admin-guide.md (Setting up IGDB credentials)  |  Twitch console: https://dev.twitch.tv/console
IGDB_CLIENT_ID=your-igdb-client-id
IGDB_CLIENT_SECRET=your-igdb-client-secret

# Docker Compose only — PostgreSQL password
# (DATABASE_URL is set automatically from this when using deploy/docker/docker-compose.yml)
POSTGRES_PASSWORD=yourpassword
